#!/usr/bin/env bash

BASE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECTS_DIR="$BASE_DIR/../projects"
PREVIEWS_DIR="$BASE_DIR/../previews"

mkdir -p "$PROJECTS_DIR"
mkdir -p "$PREVIEWS_DIR"

source "$BASE_DIR/lib/core.sh"
source "$BASE_DIR/lib/project.sh"
source "$BASE_DIR/lib/extras.sh"

CMD=${1:-}
PROJECT=${2:-}

case "$CMD" in

  new)
    create_project "$PROJECT" "${3:-php}"
    ;;

  run)
    if [ "$PROJECT" = "platform" ] || [ -z "$PROJECT" ]; then
      start_platform
    else
      start_project "$PROJECT"
    fi
    ;;

  stop)
    if [ "$PROJECT" = "platform" ] || [ -z "$PROJECT" ]; then
      stop_platform
    else
      stop_project "$PROJECT"
    fi
    ;;

  restart)
    if [ "$PROJECT" = "platform" ] || [ -z "$PROJECT" ]; then
      stop_platform
      start_platform
    else
      stop_project "$PROJECT"
      start_project "$PROJECT"
    fi
    ;;

  deploy)
    deploy_project "$PROJECT"
    ;;

  preview)
    preview_project "$PROJECT" "$3"
    ;;

  npm)
    # Se o segundo argumento não for uma pasta de projeto, tenta detectar o projeto atual
    if [ ! -d "$PROJECTS_DIR/$PROJECT" ]; then
      DETECTED_PROJECT=$(get_current_project)
      if [ -n "$DETECTED_PROJECT" ]; then
        # Se detectou projeto, então $PROJECT e os demais são argumentos do npm
        run_npm "$DETECTED_PROJECT" "$PROJECT" "${@:3}"
      else
        echo "Erro: Projeto \"$PROJECT\" não encontrado e você não está dentro de uma pasta de projeto."
        exit 1
      fi
    else
      # $PROJECT é o nome do projeto
      run_npm "$PROJECT" "${@:3}"
    fi
    ;;

  npx)
    # Se o segundo argumento não for uma pasta de projeto, tenta detectar o projeto atual
    if [ ! -d "$PROJECTS_DIR/$PROJECT" ]; then
      DETECTED_PROJECT=$(get_current_project)
      if [ -n "$DETECTED_PROJECT" ]; then
        # Se detectou projeto, então $PROJECT e os demais são argumentos do npx
        run_npx "$DETECTED_PROJECT" "$PROJECT" "${@:3}"
      else
        echo "Erro: Projeto \"$PROJECT\" não encontrado e você não está dentro de uma pasta de projeto."
        exit 1
      fi
    else
      # $PROJECT é o nome do projeto
      run_npx "$PROJECT" "${@:3}"
    fi
    ;;

  exec)
    if [ "$PROJECT" = "platform" ]; then
      run_exec "platform" "${@:3}"
    elif [ -d "$PROJECTS_DIR/$PROJECT" ] && [ -n "$PROJECT" ]; then
      run_exec "$PROJECT" "${@:3}"
    else
      DETECTED_PROJECT=$(get_current_project)
      if [ -n "$DETECTED_PROJECT" ]; then
        # No caso de exec, o PROJECT na verdade já é o comando se o projeto foi detectado
        run_exec "$DETECTED_PROJECT" "${@:2}"
      else
        echo "Erro: Alvo \"$PROJECT\" não encontrado e você não está dentro de uma pasta de projeto."
        exit 1
      fi
    fi
    ;;

  logs)
    if [ "$PROJECT" = "platform" ] || [ -z "$PROJECT" ]; then
      docker compose -f "$BASE_DIR/docker-compose.yml" logs ${3:-} ${4:-}
    elif [ -f "$PROJECTS_DIR/$PROJECT/docker-compose.extra.yml" ]; then
      docker compose -f "$PROJECTS_DIR/$PROJECT/docker-compose.extra.yml" logs ${3:-} ${4:-}
    else
      log_error "Projeto $PROJECT não encontrado ou não possui serviços extras."
    fi
    ;;

  *)
    echo "Comandos:"
    echo "dev new nome [template]         (php, static, laravel)"
    echo "dev run [nome|platform]"
    echo "dev stop [nome|platform]"
    echo "dev restart [nome|platform]"
    echo "dev logs [nome|platform] [-f]"
    echo "dev deploy nome"
    echo "dev preview nome branch"
    echo "dev npm [nome] comando      (ex: dev npm run dev ou dev npm my-project install)"
    echo "dev npx [nome] comando      (ex: dev npx tailwindcss init)"
    echo "dev exec [alvo] [serviço] comando   (ex: dev exec platform db mysql ou dev exec my-project ls)"
    ;;
esac
